@page "/claims/{mode}"
@using CompliantManager.Shared.Enums
@inject NavigationManager Navigation
@inject IClaimService _claimService
@inject IUserService _userService

<PageTitle>Zgłoszenia</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudPaper Elevation="25" Class="mb-5">
        <MudToolBar>
            <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Navigation.NavigateTo("/claim"))">Nowe</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Edit" Disabled="_dataGrid?.SelectedItems?.Count != 1" OnClick="Edit">Edytuj</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete" Disabled="_dataGrid?.SelectedItems?.Count == 0" OnClick="DeleteClaims">Usuń</MudButton>
        </MudToolBar>
    </MudPaper>

    <MudDataGrid ServerData="LoadGridData" T="ClaimDto" @ref="_dataGrid" Class="mt-5" SortMode="SortMode.None" MultiSelection="true" SelectedItemsChanged="StateHasChanged">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@_listMode.ToString() zgłoszenia</MudText>
        </ToolBarContent>
        <Columns>
            <SelectColumn T="ClaimDto" />
            <PropertyColumn Property="@(c => c.Status.ToString())" Title="Status" />
            <PropertyColumn Property="@(c => $"{c.Order.Customer.FirstName} {c.Order.Customer.LastName}")" Title="Zgłaszający" />
            <PropertyColumn Property="@(c => c.Consultant != null ? $"{c.Consultant.FirstName} {c.Consultant.LastName}" : string.Empty)" Title="Odpowiedzialny" />
            <PropertyColumn Property="@(c => c.CreatedOn.ToShortDateString())" Title="Data zgłoszenia" />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="ClaimDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>


@code {

    private MudDataGrid<ClaimDto> _dataGrid = new();

    [Parameter]
    public string Mode { get; set; }

    private ListMode _listMode;

    protected override async Task OnParametersSetAsync()
    {
        if (Enum.TryParse(Mode, ignoreCase: true, out ListMode listMode))
        {
            _listMode = listMode;
        }
        else
        {
            _listMode = ListMode.Aktywne;
        }

        await ReloadGrid();
    }

    private async Task<List<ClaimDto>> GetClaims(int pageSize, int currentPage)
    {
        var currentUser = await _userService.GetCurrentUserAsync();
        return await _claimService.GetAllAsync(pageSize, pageSize * currentPage, _listMode, currentUser.Id);
    }

    private async Task<int> GetClaimsCount()
    {
        return await _claimService.GetCountAsync();
    }

    private async Task DeleteClaims()
    {
        try
        {
            await _claimService.DeleteManyAsync(_dataGrid.SelectedItems.Select(u => u.Id).ToList());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting customers: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas usuwania klientów.", Severity.Error);
        }
        finally
        {
            await ReloadGrid();
        }
    }

    private async Task<GridData<ClaimDto>> LoadGridData(GridState<ClaimDto> state)
    {
        var currentPage = state.Page;
        var pageSize = state.PageSize;

        try
        {
            var facts = await GetClaims(pageSize, currentPage);
            var factsCount = await GetClaimsCount();

            GridData<ClaimDto> data = new()
            {
                Items = facts,
                TotalItems = factsCount
            };

            return data;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas pobierania listy klientów.", Severity.Error);
            return new GridData<ClaimDto> { Items = [], TotalItems = 0 };
        }
    }

    private void Edit()
    {
        var id = _dataGrid?.SelectedItems?.SingleOrDefault()?.Id;

        if(id is not null)
        {
            Navigation.NavigateTo($"/claim/{id}?listMode={_listMode.ToString().ToLower()}");
        }
    }

    private async Task ReloadGrid()
    {
        if (_dataGrid is not null)
            await _dataGrid.ReloadServerData();
    }
}
