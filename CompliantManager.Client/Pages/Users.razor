@page "/users"
@inject NavigationManager Navigation
@inject IUserService _userService
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Użytkownicy</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudPaper Elevation="25" Class="mb-5">
        <MudToolBar>
            <MudButton StartIcon="@Icons.Material.Filled.Edit" Disabled="_dataGrid?.SelectedItems?.Count != 1" OnClick="Edit">Edytuj</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete" Disabled="_dataGrid?.SelectedItems?.Count == 0">Usuń</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Upgrade" Disabled="_dataGrid?.SelectedItems?.Count == 0">Awansuj</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Upgrade" Disabled="_dataGrid?.SelectedItems?.Count == 0">Degraduj</MudButton>
        </MudToolBar>
    </MudPaper>

    <MudDataGrid ServerData="LoadGridData" T="UserDto" @ref="_dataGrid" Class="mt-5" SortMode="SortMode.None" MultiSelection="true" SelectedItemsChanged="StateHasChanged">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Użytkownicy</MudText>
            <MudSpacer />
            <MudTextField Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <Columns>
            <SelectColumn T="UserDto" />
            <PropertyColumn Property="@(c => c.FirstName)" Title="Imię" />
            <PropertyColumn Property="@(c => c.LastName)" Title="Nazwisko" />
            <PropertyColumn Property="@(c => c.IsAdministrator)" Title="Uprawnienia administratora" />
        </Columns>
        <PagerContent>
            <MudDataGridPager T="UserDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>


@code {

    private MudDataGrid<UserDto> _dataGrid = new();

    private async Task<List<UserDto>> GetUsers(int pageSize, int currentPage)
    {
        return await _userService.GetUsersAsync(pageSize, pageSize * currentPage);
    }

    private async Task<int> GetUsersCount()
    {
        return await _userService.GetUsersCountAsync();
    }

    private async Task<GridData<UserDto>> LoadGridData(GridState<UserDto> state)
    {
        var currentPage = state.Page;
        var pageSize = state.PageSize;

        var users = await GetUsers(pageSize, currentPage);
        var usersCount = await GetUsersCount();

        GridData<UserDto> data = new()
        {
            Items = users,
            TotalItems = usersCount
        };

        return data;
    }

    private void Edit()
    {
        var id = _dataGrid?.SelectedItems?.SingleOrDefault()?.Id;

        if (id is not null)
        {
            Navigation.NavigateTo($"/user/{id}");
        }
    }
}
