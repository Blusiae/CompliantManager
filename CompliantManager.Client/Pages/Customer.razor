@page "/customer"
@page "/customer/{id:int}"
@using Microsoft.AspNetCore.WebUtilities;
@inject NavigationManager Navigation
@inject ICustomerService _customerService

<PageTitle>CompliantManager - @(Id is null ? "Nowy klient" : $"{_customer.FirstName} {_customer.LastName}")</PageTitle>

<MudPaper Elevation="25">
    <MudToolBar>
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Class="mr-5" OnClick="@(() => Navigation.NavigateTo("/customers"))" />
        <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Navigation.NavigateTo("/customer"))">Nowy</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Save" OnClick="Save">Zapisz</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Delete" Disabled="Id is null" OnClick="Delete">Usuń</MudButton>
    </MudToolBar>
</MudPaper>

<MudPaper Class="mt-5 pa-5">
    <MudContainer Class="d-flex ms-0 px-0">
        <MudText Typo="Typo.h5" Class="mt-1">@(Id is null ? "Nowy klient" : $"{_customer.FirstName} {_customer.LastName}")</MudText>
    </MudContainer>
    <MudForm>
        <MudGrid Class="mt-1">
            <MudItem md="4">

                    <MudCard Class="py-2" Elevation="1">
                    <MudCardHeader Style="padding-bottom: 0;">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Dane osobowe</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                        <MudCardContent Style="padding-top: 0;">

                            <MudTextField @bind-Value="_customer.FirstName"
                                          Label="Imię"
                                          Required="true"
                                          For="@(() => _customer.FirstName)"
                                          ErrorText="Imię jest wymagane" Class="mt-3" />

                            <MudTextField @bind-Value="_customer.LastName"
                                          Label="Nazwisko"
                                          Required="true"
                                          For="@(() => _customer.LastName)"
                                          ErrorText="Nazwisko jest wymagane" Class="mt-3" />

                            <MudTextField @bind-Value="_customer.Email"
                                          Label="E-mail"
                                          Required="true"
                                          For="@(() => _customer.Email)"
                                          ErrorText="E-mail jest niepoprawny" Class="mt-3" />

                            <MudTextField @bind-Value="_customer.PhoneNumber"
                                          Label="Numer telefonu"
                                          Required="true"
                                          For="@(() => _customer.PhoneNumber)"
                                          ErrorText="Numer telefonu jest niepoprawny." Class="mt-3" />
                        </MudCardContent>
                    </MudCard>
            </MudItem>
            <MudItem md="4">
                <MudCard Class="py-2" Elevation="1">
                    <MudCardHeader Style="padding-bottom: 0;">
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Adres</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Style="padding-top: 0;">

                        <MudTextField @bind-Value="_customer.Country"
                                      Label="Państwo"
                                      Required="true"
                                      For="@(() => _customer.Country)"
                                      ErrorText="Państwo jest wymagane" Class="mt-3" />

                        <MudTextField @bind-Value="_customer.City"
                                      Label="Miasto"
                                      Required="true"
                                      For="@(() => _customer.City)"
                                      ErrorText="Miasto jest wymagane" Class="mt-3" />

                        <MudTextField @bind-Value="_customer.PostalCode"
                                      Label="Kod pocztowy"
                                      Required="true"
                                      For="@(() => _customer.PostalCode)"
                                      ErrorText="Kod pocztowy jest niepoprawny." 
                                      MaxLength="10" Class="mt-3" />

                        <MudTextField @bind-Value="_customer.Street"
                                      Label="Ulica"
                                      Required="true"
                                      For="@(() => _customer.Street)"
                                      ErrorText="Ulica jest wymagana." Class="mt-3" />

                        <MudTextField @bind-Value="_customer.HouseNumber"
                                      Label="Numer domu"
                                      Required="false"
                                      For="@(() => _customer.HouseNumber)"
                                      Class="mt-3" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>



@code {
    [Parameter]
    public int? Id { get; set; }

    private CustomerDto _customer = new();
    private MudForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            try
            {
                _customer = await _customerService.GetCustomerAsync(Id.Value);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error fetching customer: {ex.Message}");
                Snackbar.Add("Nie można pobrać klienta.", Severity.Error);
                Navigation.NavigateTo("/customers");
            }
        }

        base.OnInitialized();
    }

    private async Task Save()
    {
        try
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                Snackbar.Add("Uzupełnij poprawnie wszystkie pola.", Severity.Error);
                return;
            }
            if (Id is null)
            {
                var customerId = await _customerService.CreateCustomerAsync(_customer);
                Snackbar.Add("Klient został utworzony.", Severity.Success);
                Navigation.NavigateTo($"/customer/{customerId}");
            }
            else
            {
                await _customerService.UpdateCustomerAsync(_customer);
                Snackbar.Add("Klient został zaktualizowany.", Severity.Success);
                Navigation.Refresh();
            }
            Navigation.NavigateTo("/customers");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving user: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas zapisywania klienta.", Severity.Error);
        }
    }

    private async Task Delete()
    {
        if (Id is null) return;
        try
        {
            await _customerService.DeleteCustomerAsync(_customer.Id);
            Snackbar.Add("Klient został usunięty.", Severity.Success);
            Navigation.NavigateTo("/customers");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error demoting customer: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas usuwania klienta.", Severity.Error);
        }
    }
}
