@page "/user/{id}"
@using Microsoft.AspNetCore.WebUtilities;
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Administrator")]

<MudPaper Elevation="25">
    <MudToolBar>
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Class="mr-5" OnClick="@(() => Navigation.NavigateTo($"/users"))" />
        <MudButton StartIcon="@Icons.Material.Filled.Save">Zapisz</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Delete">Usuń</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Upgrade">Awansuj</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Upgrade">Degraduj</MudButton>
    </MudToolBar>
</MudPaper>

<MudPaper Class="mt-5 pa-5">
    <MudContainer Class="d-flex ms-0 px-0">
        <MudText Typo="Typo.h5" Class="mt-1">@(Id is null ? "Nowy użytkownik" : $"{_user.FirstName} {_user.LastName}")</MudText>
    </MudContainer>
    <MudGrid Class="mt-1">
        <MudItem md="4">
            <MudCard Class="py-2" Elevation="1">
                <MudCardHeader Style="padding-bottom: 0;">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Dane klienta</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="padding-top: 0;">
                    <MudTextField Label="Imię"
                                  T="string" @bind-Value="_user.FirstName" />
                    <MudTextField Label="Nazwisko" Class="mt-3"
                                  T="string" @bind-Value="_user.LastName" />
                    <MudTextField Label="Adres e-mail" Class="mt-3"
                                  T="string" @bind-Value="_user.Email" />
                    <MudSwitch Label="Uprawnienia administratora" Class="mt-3"
                                  @bind-Value="_user.IsAdministrator" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudPaper>



@code {
    [Parameter]
    public string? Id { get; set; }

    UserDto _user = new();

    protected override void OnInitialized()
    {
        if (Id is not null)
        {
            // pobranie danych
        }

        base.OnInitialized();
    }
}
