@page "/user"
@page "/user/{id:guid}"
@using Microsoft.AspNetCore.WebUtilities;
@inject NavigationManager Navigation
@inject IUserService _userService
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>CompliantManager - @(Id is null ? "Nowy użytkownik" : $"{_user.FirstName} {_user.LastName}")</PageTitle>

<MudPaper Elevation="25">
    <MudToolBar>
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Class="mr-5" OnClick="@(() => Navigation.NavigateTo("/users"))" />
        <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Navigation.NavigateTo("/user", true))">Nowy</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Save" OnClick="Save">Zapisz</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Delete" Disabled="Id is null" OnClick="Delete">Usuń</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.ArrowUpward" Disabled="_user.IsAdministrator || Id is null" OnClick="Promote">Awansuj</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.ArrowDownward" Disabled="!_user.IsAdministrator || Id is null" OnClick="Demote">Degraduj</MudButton>
    </MudToolBar>
</MudPaper>

<MudPaper Class="mt-5 pa-5">
    <MudContainer Class="d-flex ms-0 px-0">
        <MudText Typo="Typo.h5" Class="mt-1">@(Id is null ? "Nowy użytkownik" : $"{_user.FirstName} {_user.LastName}")</MudText>
    </MudContainer>
    <MudGrid Class="mt-1">
        <MudItem md="4">
            <MudCard Class="py-2" Elevation="1">
                <MudCardContent Style="padding-top: 0;">
                    <MudForm>
                        <MudTextField @bind-Value="_user.FirstName"
                                      Label="Imię"
                                      Required="true"
                                      For="@(() => _user.FirstName)"
                                      ErrorText="Imię jest wymagane" Class="mt-3" />

                        <MudTextField @bind-Value="_user.LastName"
                                      Label="Nazwisko"
                                      Required="true"
                                      For="@(() => _user.LastName)"
                                      ErrorText="Nazwisko jest wymagane" Class="mt-3" />

                        <MudTextField @bind-Value="_user.Email"
                                      Label="E-mail"
                                      Required="true"
                                      For="@(() => _user.Email)"
                                      ErrorText="E-mail jest niepoprawny" Class="mt-3" />
                        @if(Id is null)
                        {
                            <MudTextField @bind-Value="_user.Password"
                                          Label="Hasło"
                                          InputType="InputType.Password"
                                          Required="Id is null"
                                          For="@(() => _user.Password)"
                                          ErrorText="Hasło powinno mieć co najmniej jedną wielką literę oraz znak specjalny" Class="mt-3"
                                          Validation="ValidatePassword" />
                        }


                        <div class="d-flex justify-start mt-3">
                            <MudSwitch Label="Uprawnienia administratora"
                                       LabelPlacement="Placement.Left"
                                       @bind-Value="_user.IsAdministrator"
                                       For="@(() => _user.IsAdministrator)"
                                       Color="Color.Primary"
                                       ReadOnly="false"
                                       Style="@(Id is null ? "display: none" : "")" />
                        </div>
                    </MudForm>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudPaper>



@code {
    [Parameter]
    public Guid? Id { get; set; }

    private UserDto _user = new();
    private MudForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id is not null)
        {
            try
            {
                _user = await _userService.GetUserAsync(Id.Value);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error fetching user: {ex.Message}");
                Snackbar.Add("Nie można pobrać użytkownika.", Severity.Error);
                Navigation.NavigateTo("/users");
            }
        }

        base.OnInitialized();
    }

    private async Task Save()
    {
        try
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                Snackbar.Add("Uzupełnij poprawnie wszystkie pola.", Severity.Error);
                return;
            }
            if (Id is null)
            {
                Id = await _userService.CreateUserAsync(_user);
                Snackbar.Add("Użytkownik został utworzony.", Severity.Success);
                Navigation.NavigateTo($"/user/{Id}");
            }
            else
            {
                await _userService.UpdateUserAsync(_user);
                Snackbar.Add("Użytkownik został zaktualizowany.", Severity.Success);
                _user = await _userService.GetUserAsync(Id.Value);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving user: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas zapisywania użytkownika.", Severity.Error);
        }
    }

    private async Task Promote()
    {
        if (_user.IsAdministrator || Id is null) return;
        try
        {
            _user.IsAdministrator = true;
            await _userService.UpdateUserAsync(_user);
            Snackbar.Add("Użytkownik został awansowany na administratora.", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error promoting user: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas awansowania użytkownika.", Severity.Error);
        }
    }

    private async Task Demote()
    {
        if (!_user.IsAdministrator || Id is null) return;
        try
        {
            _user.IsAdministrator = false;
            await _userService.UpdateUserAsync(_user);
            Snackbar.Add("Użytkownik został zdegradowany z uprawnień administratora.", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error demoting user: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas degradacji użytkownika.", Severity.Error);
        }
    }

    private async Task Delete()
    {
        if (Id is null) return;
        try
        {
            await _userService.DeleteUserAsync(_user.Id);
            Snackbar.Add("Użytkownik został usunięty.", Severity.Success);
            Navigation.NavigateTo("/users");
        }
        catch(Exception ex)
        {
            Console.WriteLine($"Error demoting user: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas usuwania użytkownika.", Severity.Error);
        }
    }

    private IEnumerable<string> ValidatePassword(string password)
    {
        if (string.IsNullOrWhiteSpace(password))
            yield return "Hasło nie może być puste";

        if (password.Length < 8)
            yield return "Hasło musi mieć co najmniej 8 znaków";

        if (!password.Any(char.IsUpper))
            yield return "Hasło musi zawierać wielką literę";

        if (!password.Any(ch => !char.IsLetterOrDigit(ch)))
            yield return "Hasło musi zawierać cyfrę";
    }
}
