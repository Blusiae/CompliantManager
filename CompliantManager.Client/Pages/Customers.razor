@page "/customers"
@inject NavigationManager Navigation
@inject ICustomerService _customerService

<PageTitle>Klienci</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudPaper Elevation="25" Class="mb-5">
        <MudToolBar>
            <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Navigation.NavigateTo("/customer"))">Nowy</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Edit" Disabled="_dataGrid?.SelectedItems?.Count != 1" OnClick="Edit">Edytuj</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete" Disabled="_dataGrid?.SelectedItems?.Count == 0" OnClick="DeleteUsers">Usuń</MudButton>
        </MudToolBar>
    </MudPaper>

    <MudDataGrid ServerData="LoadGridData" T="CustomerDto" @ref="_dataGrid" Class="mt-5" SortMode="SortMode.None" MultiSelection="true" SelectedItemsChanged="StateHasChanged">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Klienci</MudText>
            <MudSpacer />
            <!--<MudTextField @bind-Value="_searchTerm"
                          Placeholder="Szukaj"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnBlur="ReloadGrid"
                          OnKeyUp="@(e => { if (e.Key == "Enter") ReloadGrid(); })" /> -->
        </ToolBarContent>
        <Columns>
            <SelectColumn T="CustomerDto" />
            <PropertyColumn Property="@(c => c.FirstName)" Title="Imię" />
            <PropertyColumn Property="@(c => c.LastName)" Title="Nazwisko" />
            <PropertyColumn Property="@(c => c.Email)" Title="Adres e-mail" />
            <PropertyColumn Property="@(c => c.PhoneNumber)" Title="Numer telefonu" />
        </Columns>
        <PagerContent>
            @if (_dataGrid?.Items is null || !_dataGrid.Items.Any())
            {
                <MudText Class="mt-3 mb-2 ml-3" Typo="Typo.body1">Brak klientów do wyświetlenia.</MudText>
            }
            <MudDataGridPager T="CustomerDto" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>


@code {

    private MudDataGrid<CustomerDto> _dataGrid = new();

    // private string? _searchTerm;

    private async Task<List<CustomerDto>> GetUsers(int pageSize, int currentPage)
    {
        return await _customerService.GetCustomersAsync(pageSize, pageSize * currentPage);
    }

    private async Task<int> GetUsersCount()
    {
        return await _customerService.GetCustomersCountAsync();
    }

    private async Task DeleteUsers()
    {
        try
        {
            await _customerService.DeleteCustomersAsync(_dataGrid.SelectedItems.Select(u => u.Id).ToList());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting customers: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas usuwania klientów.", Severity.Error);
        }
        finally
        {
            await ReloadGrid();
        }
    }

    private async Task<GridData<CustomerDto>> LoadGridData(GridState<CustomerDto> state)
    {
        var currentPage = state.Page;
        var pageSize = state.PageSize;

        try
        {
            var users = await GetUsers(pageSize, currentPage);
            var usersCount = await GetUsersCount();

            GridData<CustomerDto> data = new()
            {
                Items = users,
                TotalItems = usersCount
            };

            return data;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
            Snackbar.Add("Wystąpił błąd podczas pobierania listy klientów.", Severity.Error);
            return new GridData<CustomerDto> { Items = [], TotalItems = 0 };
        }

    }

    private void Edit()
    {
        var id = _dataGrid?.SelectedItems?.SingleOrDefault()?.Id;

        if (id is not null)
        {
            Navigation.NavigateTo($"/customer/{id}");
        }
    }

    private async Task ReloadGrid()
    {
        if (_dataGrid is not null)
            await _dataGrid.ReloadServerData();
    }
}
