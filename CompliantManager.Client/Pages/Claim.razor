@page "/claim/{id}"
@using Microsoft.AspNetCore.WebUtilities;
@inject NavigationManager Navigation

<MudPaper Elevation="25">
    <MudToolBar>
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Class="mr-5" OnClick="@(() => Navigation.NavigateTo($"/claims/{_listMode}"))" />
        <MudButton StartIcon="@Icons.Material.Filled.Save">Zapisz</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Delete">Usuń</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Person">Przejmij</MudButton>
    </MudToolBar>
</MudPaper>

<MudPaper Class="mt-5 pa-5">
    <MudContainer Class="d-flex ms-0 px-0">
        <MudText Typo="Typo.h5" Class="mt-1">Zgłoszenie #@Id</MudText>
        <MudChip T="string" Variant="Variant.Text" Color="Color.Success" Class="mx-3">Aktywne</MudChip>
    </MudContainer>
    <MudText Typo="Typo.overline">Odpowiedzialny: Imię Nazwisko</MudText>
    <MudGrid Class="mt-1">
        <MudItem md="4">
            <MudCard Class="py-2" Elevation="1">
                <MudCardHeader Style="padding-bottom: 0;">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Dane klienta</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Default" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="padding-top: 0;">
                    <MudTextField Label="Imię"
                                  T="string" />
                    <MudTextField Label="Nazwisko" Class="mt-3"
                                  T="string" />
                    <MudTextField Label="Adres e-mail" Class="mt-3"
                                  T="string" />
                    <MudTextField Label="Numer telefonu" Class="mt-3"
                                  T="string" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudPaper>



@code {
    [Parameter]
    public string? Id { get; set; } // jesli null to znaczy ze jest to nowy claim

    private string _listMode = "active";

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("listMode", out var listMode))
        {
            _listMode = listMode;
        }


        base.OnInitialized();
    }
}
